# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# F1 diagnostic transient state
runners/.f1-fixtures/
runners/*-checkpoint.json
runners/*-results.json
runners/*-preflight-failure.json

# Bundle 3.75 fixture cache for Serper + GitHub responses
# Populated by cache-on-miss during verification runs with IDEALOOP_USE_FIXTURES=1
# .gitkeep retained to preserve directory in repo
runners/fixtures/data/*.json

# Local test corpora, runners, and verification outputs (never deployed)
B10a-*
v50-*
cases.js
syn-cases.js
archetype-cases.js
audit-*
delta_vs_*
b10a-*.log
run-b*.js
run-archetypes.js
run-audit.js
run-variance.js
rescore-*.js
/runners/
run-v50.js
attribute-stage1.js
populate-search.js

# F4 failure-mode harness + local verification scripts (root-level, never deployed)
/run-f4-*.js
/verify-*.mjs
/mock-*.mjs
/analyze-*.mjs